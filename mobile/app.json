{
  "expo": {
    "name": "EduWave Village",
    "slug": "eduwave-village",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "scheme": "eduwave",
    "ios": {
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "EduWave Village uses your location to find nearby support resources."
      }
    },
    "android": {
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    }
  }
}
